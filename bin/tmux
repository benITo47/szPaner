#!/usr/bin/env bash

# tmux wrapper for szPaner
# Intercepts zone names, passes through everything else

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Find the real tmux binary
find_real_tmux() {
    local this_script="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/tmux"

    # Try common locations, excluding this wrapper
    for path in /opt/homebrew/bin/tmux /usr/local/bin/tmux /usr/bin/tmux; do
        if [[ -x "$path" ]] && [[ "$path" != "$this_script" ]]; then
            echo "$path"
            return 0
        fi
    done

    return 1
}

REAL_TMUX=$(find_real_tmux)

if [[ -z "$REAL_TMUX" ]]; then
    echo "Error: Could not find real tmux binary" >&2
    exit 1
fi

# Pass through if no args, flags, or known tmux commands
if [[ $# -eq 0 ]] || [[ "$1" == -* ]] || [[ "$1" =~ ^(new|attach|detach|ls|list|kill|switch|source|show|set|display|run|send|split|select|resize|rename|move|swap|choose|find|capture|save|load|refresh|clock|lock|suspend|paste|copy|delete|buffer|unbind|bind)(-|$) ]]; then
    exec "$REAL_TMUX" "$@"
fi

# Might be a zone - try to spawn it
if [[ "$1" =~ ^[a-zA-Z0-9_-]+$ ]]; then
    source "$SCRIPT_DIR/scripts/parse-config.sh"

    # Find config
    for config in "$HOME/.szpaner/zones.conf" "$HOME/.config/szpaner/zones.conf" "$SCRIPT_DIR/zones.conf" "$SCRIPT_DIR/examples/dev.conf"; do
        if [[ -f "$config" ]]; then
            if parse_config_file "$config" 2>/dev/null; then
                # Check if it's a zone
                for zone in "${all_zones[@]}"; do
                    if [[ "$zone" == "$1" ]]; then
                        exec "$SCRIPT_DIR/scripts/spawn-zone.sh" "$1" "${2:-$1}" "$config"
                    fi
                done
            fi
            break
        fi
    done
fi

# Not a zone, pass through
exec "$REAL_TMUX" "$@"
