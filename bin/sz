#!/usr/bin/env bash

# tmux wrapper - Spawn Zone
# Intercepts zone names, otherwise passes through to real tmux

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Find the real tmux binary (not this wrapper)
REAL_TMUX=""
for path in /usr/local/bin/tmux /opt/homebrew/bin/tmux /usr/bin/tmux; do
    if [[ -x "$path" ]] && [[ "$path" != "${BASH_SOURCE[0]}" ]]; then
        REAL_TMUX="$path"
        break
    fi
done

if [[ -z "$REAL_TMUX" ]]; then
    echo "Error: Could not find real tmux binary" >&2
    exit 1
fi

# Source the parser
source "$SCRIPT_DIR/scripts/parse-config.sh"

# Find config file
find_config() {
    local config_locations=(
        "$HOME/.szpaner/zones.conf"
        "$HOME/.config/szpaner/zones.conf"
        "$SCRIPT_DIR/zones.conf"
    )

    for config in "${config_locations[@]}"; do
        if [[ -f "$config" ]]; then
            echo "$config"
            return 0
        fi
    done

    return 1
}

# List available zones
list_zones() {
    local config_file="$1"

    if [[ ! -f "$config_file" ]]; then
        echo "Error: No config file found" >&2
        echo "Create one at: ~/.szpaner/zones.conf" >&2
        return 1
    fi

    # Parse config
    parse_config_file "$config_file" 2>/dev/null

    if [[ ${#all_zones[@]} -eq 0 ]]; then
        echo "No zones defined in config" >&2
        return 1
    fi

    echo "Available zones:"
    for zone in "${all_zones[@]}"; do
        local panes=(${zone_panes[$zone]})
        echo "  $zone (${#panes[@]} panes)"
    done
}

# Show usage
show_usage() {
    local config_file="$1"

    cat << 'EOF'
sz - Spawn tmux zones

Usage:
  sz <zone>              Spawn a zone in current/new session
  sz <zone> <session>    Spawn a zone in specific session
  sz -l, --list          List available zones
  sz -h, --help          Show this help

Examples:
  sz dev                 Spawn 'dev' zone
  sz servers work        Spawn 'servers' zone in 'work' session

EOF

    if [[ -n "$config_file" ]]; then
        echo "Config: $config_file"
        echo ""
        list_zones "$config_file"
    fi
}

# Main
main() {
    local zone_name=""
    local session_name=""
    local config_file

    # Find config file
    if ! config_file=$(find_config); then
        # No config found - just open a normal tmux session with a helpful message
        local sess="${session_name:-szpaner}"

        if ! tmux has-session -t "$sess" 2>/dev/null; then
            tmux new-session -d -s "$sess"
        fi

        tmux send-keys -t "$sess" "echo 'szPaner: No config file found'" C-m
        tmux send-keys -t "$sess" "echo ''" C-m
        tmux send-keys -t "$sess" "echo 'Create a config at:'" C-m
        tmux send-keys -t "$sess" "echo '  ~/.szpaner/zones.conf'" C-m
        tmux send-keys -t "$sess" "echo '  ~/.config/szpaner/zones.conf'" C-m
        tmux send-keys -t "$sess" "echo ''" C-m
        tmux send-keys -t "$sess" "echo 'Example: https://github.com/benito47/szpaner/blob/main/examples/dev.conf'" C-m

        if [ -z "$TMUX" ]; then
            exec tmux attach-session -t "$sess"
        else
            exec tmux switch-client -t "$sess"
        fi
    fi

    # Parse arguments
    case "${1:-}" in
        -h|--help|help)
            show_usage "$config_file"
            exit 0
            ;;
        -l|--list|list)
            list_zones "$config_file"
            exit 0
            ;;
        "")
            show_usage "$config_file"
            exit 0
            ;;
        *)
            zone_name="$1"
            session_name="${2:-szpaner}"
            ;;
    esac

    # Spawn the zone
    exec "$SCRIPT_DIR/scripts/spawn-zone.sh" "$zone_name" "$session_name" "$config_file"
}

main "$@"
